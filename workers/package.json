{
  "name": "tako-mcp-workers",
  "version": "0.0.0",
  "private": true,
  "description": "Tako MCP server on Cloudflare Workers (mcp.tako.com).",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
