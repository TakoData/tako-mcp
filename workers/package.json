{
  "name": "tako-mcp-workers",
  "version": "0.1.0",
  "private": true,
  "description": "Tako MCP server on Cloudflare Workers (mcp.tako.com).",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "dev:staging": "wrangler dev --env staging",
    "deploy:staging": "wrangler deploy --env staging",
    "predeploy:staging": "npm run registry:gen",
    "deploy:production": "wrangler deploy --env production",
    "predeploy:production": "npm run registry:gen",
    "cf-typegen": "wrangler types",
    "registry:gen": "tsx scripts/gen-registry.ts",
    "registry:check": "tsx scripts/gen-registry.ts --check"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.11",
    "@cloudflare/workers-types": "^4.20250617.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "3.2.4",
    "wrangler": "^4.40.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
