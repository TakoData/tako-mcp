    "deploy:production": "wrangler deploy --env production"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.11",
    "@cloudflare/workers-types": "^4.20250617.0",
    "typescript": "^5.9.2",
    "vitest": "3.2.4",
    "wrangler": "^4.40.3"
  }
}
